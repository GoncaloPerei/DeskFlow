<UserControl x:Class="DeskFlow.Views.Technician.TechnicianProfileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="30">
            <Border Background="White" CornerRadius="12" Padding="30" BorderThickness="1" BorderBrush="#E2E8F0">
                <StackPanel MaxWidth="500" HorizontalAlignment="Left">

                    <TextBlock Text="Technician Profile" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,5"/>
                    <TextBlock Text="Manage your professional information as a technician." FontSize="13" Foreground="#64748B" Margin="0,0,0,25"/>

                    <TextBlock Text="Full Name:" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtTechName" Height="38" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,16"/>

                    <TextBlock Text="Corporate Email:" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtTechEmail" Height="38" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,16" Background="#F1F5F9"/>

                    <TextBlock Text="Specialization:" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,16"/>
                    <TextBox x:Name="txtTechSpecialization" Height="38" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,25"/>

                    <Button x:Name="btnSaveTech" Content="✏️ Edit Profile" Height="40" Width="170"
                            Background="#0F172A" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Click="btnSaveTech_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>