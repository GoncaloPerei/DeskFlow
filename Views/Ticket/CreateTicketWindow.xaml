<Window x:Class="DeskFlow.Views.Ticket.CreateTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeskFlow - Abrir Novo Ticket" Height="480" Width="460"
        WindowStartupLocation="CenterOwner" Background="#F8FAFC"
        ResizeMode="NoResize">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="121*"/>
            <RowDefinition Height="17*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.RowSpan="2" Margin="0,0,0,-8">
            <TextBlock Text="New Ticket" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,5"/>
            <TextBlock Text="Describe the problem in as much detail as possible." FontSize="12" Foreground="#64748B" Margin="0,0,0,20"/>

            <TextBlock Text="Title:" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,6"/>
            <TextBox x:Name="txtTitle" Height="35" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,15"/>

            <TextBlock Text="Priority Level:" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,6"/>
            <ComboBox x:Name="cmbPriority" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,15">
                <ComboBoxItem Content="Low" IsSelected="True"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
            </ComboBox>

            <TextBlock Text="Description:" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,6"/>
            <TextBox x:Name="txtDescription" Height="120" TextWrapping="Wrap" AcceptsReturn="True" Padding="8" VerticalScrollBarVisibility="Auto" Margin="0,0,0,25"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnCancel" Grid.Column="0" Content="Cancel" Height="38" Margin="0,0,8,0"
                        Background="#94A3B8" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Click="btnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnSave" Grid.Column="1" Content="Submit Ticket 🚀" Height="38" Margin="8,0,0,0"
                        Background="#38BDF8" Foreground="#0F172A" FontWeight="Bold" BorderThickness="0" Click="btnSave_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</Window>