<Window x:Class="DeskFlow.Views.Ticket.TicketDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeskFlow - Detalhes do Ticket" Height="600" Width="550"
        WindowStartupLocation="CenterScreen" Background="#F1F5F9">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                BorderThickness="1" BorderBrush="#E2E8F0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="lblTicketTitle" Text="Erro no Acesso ao Servidor" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>

                        <TextBlock x:Name="lblCreatedAt" Text="25/06/2026 10:30" FontSize="10" FontWeight="SemiBold" Foreground="#94A3B8" Margin="10,0,0,0" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Border x:Name="brdUrgency" Background="#FEE2E2" CornerRadius="4" Padding="6,2">
                            <TextBlock x:Name="lblUrgency" Text="ALTA" FontSize="10" FontWeight="Bold" Foreground="#EF4444"/>
                        </Border>
                        <Border x:Name="brdStatus" Background="#DCFCE7" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                            <TextBlock x:Name="lblStatus" Text="Aberto" FontSize="10" FontWeight="Bold" Foreground="#22C55E"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="lblDescription" 
                       Text="Esta é a descrição detalhada do problema que o utilizador reportou ao abrir o ticket." 
                       FontSize="11" 
                       Foreground="#475569" 
                       Margin="0,12,0,0" 
                       TextWrapping="Wrap"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="btnCloseTicket" Content="🔒 Fechar Ticket" 
                        Background="#EF4444" Foreground="White" FontWeight="Bold" 
                        Padding="10,0" Height="35" VerticalAlignment="Center"
                        BorderThickness="0" Click="btnCloseTicket_Click"/>
            </Grid>
        </Border>

        <ListBox Grid.Row="1" x:Name="lbInterventions" Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,15">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="8" Padding="12" Margin="0,4,0,4"
                            BorderThickness="1" BorderBrush="#E2E8F0" Width="480">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Person.Name}" FontWeight="Bold" Foreground="#1E293B" FontSize="13"/>
                                <TextBlock Grid.Column="1" Text="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Foreground="#94A3B8" FontSize="11"/>
                            </Grid>

                            <TextBlock Text="{Binding Message}" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#334155" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtReply" Grid.Column="0" Height="40" 
                     VerticalContentAlignment="Center" Padding="10,0"
                     BorderThickness="1" BorderBrush="#CBD5E1" Margin="0,0,10,0"/>

            <Button x:Name="btnSendReply" Grid.Column="1" Content="Enviar ➡️" 
                    Background="#0F172A" Foreground="White" FontWeight="SemiBold"
                    BorderThickness="0" Click="btnSendReply_Click"/>
        </Grid>
    </Grid>
</Window>