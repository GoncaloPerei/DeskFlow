<Window x:Class="DeskFlow.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeskFlow - Registro" Height="500" Width="350" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="DeskFlow" FontSize="28" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Create Account" FontSize="14" Foreground="Gray"
                       HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <Label Content="Full Name:" FontWeight="SemiBold" Margin="0,0,0,2"/>
            <TextBox x:Name="txtFullName" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

            <Label Content="Email Address:" FontWeight="SemiBold" Margin="0,0,0,2"/>
            <TextBox x:Name="txtEmail" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

            <Label Content="Password:" FontWeight="SemiBold" Margin="0,0,0,2"/>
            <PasswordBox x:Name="txtPassword" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

            <Label Content="Confirm Password:" FontWeight="SemiBold" Margin="0,0,0,2"/>
            <PasswordBox x:Name="txtConfirmPassword" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

            <Button x:Name="btnRegister" Content="Register" Height="35" FontWeight="Bold"
                    Click="btnRegister_Click" Margin="0,0,0,15"/>

            <Button x:Name="btnBackToLogin" Content="Already have an account? Log in here"
                    Background="Transparent" BorderThickness="0" Foreground="Blue" Cursor="Hand"
                    Click="btnBackToLogin_Click"/>
        </StackPanel>
    </Grid>
</Window>